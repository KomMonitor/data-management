<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext" xmlns:pro="http://www.liquibase.org/xml/ns/pro" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd http://www.liquibase.org/xml/ns/pro http://www.liquibase.org/xml/ns/pro/liquibase-pro-latest.xsd http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet author="kommonitor" id="kommonitor-5.2.0-1">
        <addColumn schemaName= "public" tableName="topics">
            <column name="displayorder" type="INTEGER" value="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet author="kommonitor" id="kommonitor-5.2.0-2">
        <createTable tableName="topicordermode">
            <column name="topicresource" type="SMALLINT"/>
            <column name="ordermode" type="SMALLINT"/>
        </createTable>
    </changeSet>
    <changeSet author="kommonitor" id="kommonitor-5.2.0-3">
        <addUniqueConstraint columnNames="topicresource" constraintName="topicresource_unique" tableName="topicordermode"/>
    </changeSet>
    <changeSet author="kommonitor" id="kommonitor-5.2.0-4">
        <insert tableName="topicordermode">
            <column name="topicresource" value="0" />
            <column name="ordermode" value="0" />
        </insert>
    </changeSet>
    <changeSet author="kommonitor" id="kommonitor-5.2.0-5">
        <insert tableName="topicordermode">
            <column name="topicresource" value="1" />
            <column name="ordermode" value="0" />
        </insert>
    </changeSet>
    <changeSet author="kommonitor" id="kommonitor-5.2.0-6">
        <createTable tableName="metadataservices">
            <column name="id" type="VARCHAR(255)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="metadataservices_pkey"/>
            </column>
            <column name="title" type="VARCHAR(255)"/>
            <column name="description" type="TEXT"/>
            <column name="topicreference" type="VARCHAR(255)"/>
            <column name="ispublic" type="BOOLEAN"/>
            <column name="serviceresource" type="SMALLINT"/>
            <column name="databasis" type="TEXT"/>
            <column name="datasource" type="TEXT"/>
            <column name="contact" type="TEXT"/>
            <column name="note" type="TEXT"/>
            <column name="owner_organizationalunitid" type="VARCHAR(255)"/>
            <column name="connectiondetailsid" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>
    <changeSet author="kommonitor" id="kommonitor-5.2.0-7">
        <createTable tableName="connectiondetails">
            <column name="id" type="VARCHAR(255)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="connectiondetails_pkey"/>
            </column>
            <column name="servicetype" type="SMALLINT"/>
        </createTable>
    </changeSet>
    <changeSet author="kommonitor" id="kommonitor-5.2.0-8">
        <createTable tableName="wmsconnectiondetails">
            <column name="id" type="VARCHAR(255)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="wmsconnectiondetails_pkey"/>
            </column>
            <column name="baseurl" type="TEXT"/>
            <column name="layername" type="TEXT"/>
        </createTable>
    </changeSet>
    <changeSet author="kommonitor" id="kommonitor-5.2.0-9">
        <createTable tableName="metadataservices_permissions">
            <column name="metadataservices_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="permission_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet author="kommonitor" id="kommonitor-5.2.0-10">
        <addForeignKeyConstraint
                baseColumnNames="connectiondetailsid"
                baseTableName="metadataservices"
                constraintName="fk_metadataservices_connectiondetails"
                deferrable="false"
                initiallyDeferred="false"
                onDelete="NO ACTION"
                onUpdate="NO ACTION"
                referencedColumnNames="id"
                referencedTableName="connectiondetails"
                validate="true"/>
    </changeSet>
    <changeSet author="kommonitor" id="kommonitor-5.2.0-11">
        <addForeignKeyConstraint
                baseColumnNames="id"
                baseTableName="wmsconnectiondetails"
                constraintName="fk_wmsconnectiondetails_connectiondetails"
                deferrable="false"
                initiallyDeferred="false"
                onDelete="NO ACTION"
                onUpdate="NO ACTION"
                referencedColumnNames="id"
                referencedTableName="connectiondetails"
                validate="true"/>
    </changeSet>
    <changeSet author="kommonitor" id="kommonitor-5.2.0-12">
        <addForeignKeyConstraint
                baseColumnNames="owner_organizationalunitid"
                baseTableName="metadataservices"
                constraintName="fk_metadataservices_organizationalunits"
                deferrable="false"
                initiallyDeferred="false"
                onDelete="NO ACTION"
                onUpdate="NO ACTION"
                referencedColumnNames="organizationalunitid"
                referencedTableName="organizationalunits"
                validate="true"/>
    </changeSet>
    <changeSet author="kommonitor" id="kommonitor-5.2.0-13">
        <addForeignKeyConstraint
                baseColumnNames="permission_id"
                baseTableName="metadataservices_permissions"
                constraintName="fk_metadataservices_permissions_permission"
                deferrable="false"
                initiallyDeferred="false"
                onDelete="NO ACTION"
                onUpdate="NO ACTION"
                referencedColumnNames="permissionid"
                referencedTableName="permissions"
                validate="true"/>
    </changeSet>
    <changeSet author="kommonitor" id="kommonitor-5.2.0-14">
        <addForeignKeyConstraint
                baseColumnNames="metadataservices_id"
                baseTableName="metadataservices_permissions"
                constraintName="fk_metadataservices_permissions_metadataservice"
                deferrable="false"
                initiallyDeferred="false"
                onDelete="NO ACTION"
                onUpdate="NO ACTION"
                referencedColumnNames="id"
                referencedTableName="metadataservices"
                validate="true"/>
    </changeSet>
    <changeSet author="kommonitor" id="kommonitor-5.2.0-15">
        <addColumn schemaName= "public" tableName="lastmodification">
            <column name="webservices" type="TIMESTAMP WITH TIME ZONE"/>
        </addColumn>
    </changeSet>
    <changeSet author="kommonitor" id="kommonitor-5.2.0-16">
        <createTable tableName="webservices_favourites">
            <column name="user_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="webservice_id" type="VARCHAR(255)">
                <constraints nullable="false" />
            </column>
        </createTable>
    </changeSet>
    <changeSet author="kommonitor" id="kommonitor-5.2.0-17">
        <addForeignKeyConstraint
                baseColumnNames="user_id"
                baseTableName="webservices_favourites"
                constraintName="fk_webservices_favourites_userinfo"
                deferrable="false"
                initiallyDeferred="false"
                onDelete="NO ACTION"
                onUpdate="NO ACTION"
                referencedColumnNames="userinfoid"
                referencedTableName="userinfo"
                validate="true"/>
    </changeSet>
    <changeSet author="kommonitor" id="kommonitor-5.2.0-18">
        <addForeignKeyConstraint
                baseColumnNames="webservice_id"
                baseTableName="webservices_favourites"
                constraintName="fk_webservices_favourites_dataset"
                deferrable="false"
                initiallyDeferred="false"
                onDelete="NO ACTION"
                onUpdate="NO ACTION"
                referencedColumnNames="id"
                referencedTableName="metadataservices"
                validate="true"/>
    </changeSet>
</databaseChangeLog>