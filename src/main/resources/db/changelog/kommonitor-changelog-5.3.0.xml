<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext" xmlns:pro="http://www.liquibase.org/xml/ns/pro" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd http://www.liquibase.org/xml/ns/pro http://www.liquibase.org/xml/ns/pro/liquibase-pro-latest.xsd http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet author="kommonitor" id="kommonitor-5.3.0-1">
        <addColumn schemaName= "public" tableName="defaultclassificationmappingitemtype">
            <column name="labels" type="VARCHAR(255) []">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet author="kommonitor" id="kommonitor-5.3.0-2">
        <addColumn schemaName= "public" tableName="defaultclassificationmappingitemtype">
            <column name="individualcolors" type="VARCHAR(255) []">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet author="kommonitor" id="kommonitor-5.3.0-3">
        <addColumn schemaName= "public" tableName="metadataindicators">
            <column name="classificationtype" type="SMALLINT"/>
        </addColumn>
    </changeSet>
    <changeSet author="kommonitor" id="kommonitor-5.3.0-4">
        <update schemaName= "public" tableName="metadataindicators">
            <column name="classificationtype" value="0"/>
        </update>
    </changeSet>
    <changeSet author="kommonitor"  id="kommonitor-5.3.0-5">
        <addNotNullConstraint columnName="classificationtype"
                              schemaName="public"
                              tableName="metadataindicators"/>
    </changeSet>

    <changeSet author="kommonitor" id="kommonitor-5.3.0-6">
        <createTable tableName="qualitativeclassificationmappingitemtype">
            <column name="mappingid" type="VARCHAR(255)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="qualitativeclassificationmappingitemtype_pkey"/>
            </column>
            <column name="spatialunitid" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet author="kommonitor" id="kommonitor-5.3.0-7">
        <createTable tableName="categorical_mapping_item">
            <column name="id" type="BIGSERIAL">
                <constraints nullable="false" primaryKey="true" primaryKeyName="categorical_mapping_item_pkey"/>
            </column>
            <column name="mappingid" type="VARCHAR(255)">
                <constraints
                        nullable="false"
                        foreignKeyName="fk_categorical_mapping_parent"
                        referencedTableName="qualitativeclassificationmappingitemtype"
                        referencedColumnNames="mappingid"
                        deleteCascade="true"/>
            </column>
            <column name="categorical_value" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="color" type="VARCHAR(9)">
                <constraints nullable="false"/>
            </column>
            <column name="label" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>
    <changeSet author="kommonitor" id="kommonitor-5.3.0-8">
        <createTable tableName="metadataindicators_qualitativeclassification">
            <column name="dataset_id" type="VARCHAR(255)">
                <constraints nullable="false"
                             foreignKeyName="fk_meta_qualitative_dataset"
                             referencedTableName="metadataindicators"
                             referencedColumnNames="datasetid"
                             deleteCascade="true"/>
            </column>
            <column name="mapping_id" type="VARCHAR(255)">
                <constraints
                        nullable="false"
                        unique="true"
                        foreignKeyName="fk_meta_qualitative_mapping"
                        referencedTableName="qualitativeclassificationmappingitemtype"
                        referencedColumnNames="mappingid"
                        deleteCascade="true"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>